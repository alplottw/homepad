{
  "manifest_version": 3,
  "name": "Homepad",
  "version": "0.1.0",
  "description": "A customizable Chrome home page. Replaces the new tab page with a Google-style main area plus a sidebar of open tabs and a read-later list.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["tabs", "topSites", "storage", "favicon"],
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
